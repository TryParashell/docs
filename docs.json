{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Parashell Documentation",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://parashell.cloud/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://parashell.cloud/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@parashell.cloud"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dash.parashell.cloud"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/TryParashell",
      "linkedin": "https://linkedin.com/company/parashell"
    }
  }
}