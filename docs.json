          "agent/python-reference-modeling",
          "agent/python-reference-workbenches",
          "agent/python-reference-misc"
        ]
      },
      {
        "group": "MCP Tools",
        "pages": [
          "agent/tools/index",
          "agent/tools/document-objects",
          "agent/tools/inspection-rendering",
          "agent/tools/sketch-spreadsheet",
          "agent/tools/geometry-builders",
